<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EllahColNum.Setup.InstallerWindow"
        Title="ELLAH-ColNum Pro — Installer"
        Width="540" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#13131f"
        FontFamily="Segoe UI">

  <Window.Resources>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"      Value="#89B4FA"/>
      <Setter Property="Foreground"      Value="#13131f"/>
      <Setter Property="FontWeight"      Value="Bold"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="28,10"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#a6c8ff"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                <Setter Property="Foreground" Value="#585B70"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button">
      <Setter Property="Background"      Value="#1e1e2e"/>
      <Setter Property="Foreground"      Value="#8892A4"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="BorderBrush"     Value="#313244"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="18,8"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#252535"/>
                <Setter Property="Foreground" Value="#CDD6F4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnDone" TargetType="Button">
      <Setter Property="Background"      Value="#A6E3A1"/>
      <Setter Property="Foreground"      Value="#13131f"/>
      <Setter Property="FontWeight"      Value="Bold"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="28,10"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#c3f0be"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- Accent top bar -->
      <RowDefinition Height="Auto"/>   <!-- Header -->
      <RowDefinition Height="Auto"/>   <!-- Feature pills -->
      <RowDefinition Height="*"/>      <!-- Log area -->
      <RowDefinition Height="Auto"/>   <!-- Progress -->
      <RowDefinition Height="Auto"/>   <!-- Bottom bar -->
    </Grid.RowDefinitions>

    <!-- ── Accent top bar ──────────────────────────────────────────── -->
    <Border Grid.Row="0" Height="4">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="#89B4FA" Offset="0"/>
          <GradientStop Color="#CBA6F7" Offset="0.5"/>
          <GradientStop Color="#A6E3A1" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ── Header ──────────────────────────────────────────────────── -->
    <Border Grid.Row="1" Background="#181825" Padding="32,24,32,20">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="ELLAH-ColNum Pro"
                     FontSize="26" FontWeight="Bold" Foreground="#89B4FA"/>
          <TextBlock Text="Smart Column Numbering for Revit 2024 / 2025 / 2026 / 2027"
                     FontSize="12" Foreground="#6C7086" Margin="0,4,0,0"/>
          <TextBlock x:Name="VersionText" Text="Version 1.0.0"
                     FontSize="10" Foreground="#45475A" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Logo badge -->
        <Border Grid.Column="1" Background="#252540" CornerRadius="10"
                Padding="14,10" VerticalAlignment="Center">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="✦" FontSize="22" Foreground="#89B4FA"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="ELLAH" FontSize="9" FontWeight="Bold"
                       Foreground="#45475A" HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- ── Feature pills ───────────────────────────────────────────── -->
    <Border Grid.Row="2" Background="#1a1a2a" Padding="32,12">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <Border Background="#1e2f4a" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
          <TextBlock Text="All Floors" Foreground="#89B4FA" FontSize="11"/>
        </Border>
        <Border Background="#1b3a2a" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
          <TextBlock Text="Smart Continue" Foreground="#A6E3A1" FontSize="11"/>
        </Border>
        <Border Background="#2a1e3a" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
          <TextBlock Text="Live Preview" Foreground="#CBA6F7" FontSize="11"/>
        </Border>
        <Border Background="#3a2a1b" CornerRadius="12" Padding="10,4">
          <TextBlock Text="One-Click Undo" Foreground="#F9E2AF" FontSize="11"/>
        </Border>
      </StackPanel>
    </Border>

    <!-- ── Log area ────────────────────────────────────────────────── -->
    <Border Grid.Row="3" Background="#0f0f1a" Margin="0,0,0,0">
      <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                    Padding="32,14">
        <TextBlock x:Name="LogText" FontSize="11" FontFamily="Consolas"
                   Foreground="#A6E3A1" TextWrapping="Wrap"/>
      </ScrollViewer>
    </Border>

    <!-- ── Progress bar ────────────────────────────────────────────── -->
    <ProgressBar x:Name="Progress" Grid.Row="4" Height="4"
                 Background="#1a1a2a" Foreground="#89B4FA"
                 BorderThickness="0"
                 Minimum="0" Maximum="100" Value="0"/>

    <!-- ── Bottom bar ──────────────────────────────────────────────── -->
    <Border Grid.Row="5" Background="#181825" Padding="32,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="StatusLabel" Grid.Column="0"
                   FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>

        <!-- Terms of Use (always visible) -->
        <Button x:Name="TermsBtn" Grid.Column="1"
                Content="Terms of Use"
                Style="{StaticResource BtnSecondary}"
                Click="TermsBtn_Click"/>

        <!-- Install / Installed -->
        <Button x:Name="InstallBtn" Grid.Column="3"
                Content="  Install  "
                Style="{StaticResource BtnPrimary}"
                Click="InstallBtn_Click"/>

        <!-- Done (hidden until install succeeds) -->
        <Button x:Name="DoneBtn" Grid.Column="5"
                Content="✓  Done"
                Style="{StaticResource BtnDone}"
                Visibility="Collapsed"
                Click="DoneBtn_Click"/>

      </Grid>
    </Border>

  </Grid>
</Window>
