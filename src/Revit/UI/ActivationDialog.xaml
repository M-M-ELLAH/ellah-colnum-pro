<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EllahColNum.Revit.UI.ActivationDialog"
        Title="ELLAH-ColNum Pro — Activation"
        Width="480" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

  <Window.Resources>
    <Style x:Key="BtnBase" TargetType="Button">
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="20,9"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="5"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="36,30,36,28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Logo + title -->
      <RowDefinition Height="16"/>
      <RowDefinition Height="1"/>     <!-- Divider -->
      <RowDefinition Height="20"/>
      <RowDefinition Height="Auto"/>  <!-- Machine ID box -->
      <RowDefinition Height="20"/>
      <RowDefinition Height="Auto"/>  <!-- Key input -->
      <RowDefinition Height="10"/>
      <RowDefinition Height="Auto"/>  <!-- Status message -->
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>  <!-- Buttons -->
    </Grid.RowDefinitions>

    <!-- Title -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="ELLAH-ColNum Pro"
                 FontSize="22" FontWeight="Bold" Foreground="#89B4FA"/>
      <TextBlock Text="License Activation"
                 FontSize="13" Foreground="#6C7086" Margin="0,4,0,0"/>
    </StackPanel>

    <Rectangle Grid.Row="2" Fill="#313244"/>

    <!-- Machine ID -->
    <StackPanel Grid.Row="4">
      <TextBlock Text="YOUR MACHINE ID" FontSize="10" FontWeight="SemiBold"
                 Foreground="#45475A" Margin="0,0,0,6"/>
      <Border Background="#181825" CornerRadius="5" Padding="14,10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="TxtMachineId"
                     FontFamily="Consolas" FontSize="15"
                     Foreground="#CBA6F7" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1" x:Name="CopyBtn"
                  Content="Copy" Style="{StaticResource BtnBase}"
                  Background="#313244" Foreground="#CDD6F4"
                  FontSize="11" Padding="10,5"
                  Click="CopyBtn_Click"/>
        </Grid>
      </Border>
      <TextBlock Text="Send this ID to ELLAH when purchasing to receive your license key."
                 FontSize="11" Foreground="#45475A"
                 TextWrapping="Wrap" Margin="0,6,0,0"/>
    </StackPanel>

    <!-- Key input -->
    <StackPanel Grid.Row="6">
      <TextBlock Text="LICENSE KEY" FontSize="10" FontWeight="SemiBold"
                 Foreground="#45475A" Margin="0,0,0,6"/>
      <TextBox x:Name="TxtKey"
               Background="#313244" Foreground="#CDD6F4"
               BorderBrush="#45475A" BorderThickness="1"
               Padding="12,8" FontSize="14" FontFamily="Consolas"
               CaretBrush="#89B4FA"
               CharacterCasing="Upper"
               Height="40"
               KeyDown="TxtKey_KeyDown"
               TextChanged="TxtKey_TextChanged"
               ToolTip="Format: ELLAH-XXXXX-XXXXX-XXXXX-XXXXX"/>
    </StackPanel>

    <!-- Status message -->
    <Border x:Name="StatusBorder" Grid.Row="8"
            CornerRadius="4" Padding="10,7"
            Visibility="Collapsed">
      <TextBlock x:Name="TxtStatus"
                 FontSize="12" TextWrapping="Wrap"/>
    </Border>

    <!-- Buttons -->
    <Grid Grid.Row="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button x:Name="CancelBtn"
              Content="Cancel"
              Style="{StaticResource BtnBase}"
              Background="#313244" Foreground="#CDD6F4"
              Click="CancelBtn_Click"/>

      <Button x:Name="ActivateBtn" Grid.Column="2"
              Content="Activate"
              Style="{StaticResource BtnBase}"
              Background="#89B4FA" Foreground="#1E1E2E"
              IsEnabled="False"
              Click="ActivateBtn_Click"/>
    </Grid>

  </Grid>
</Window>
