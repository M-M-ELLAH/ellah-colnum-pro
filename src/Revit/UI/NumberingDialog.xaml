<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EllahColNum.Revit.UI.NumberingDialog"
        Title="ELLAH-ColNum Pro — Column Numbering"
        Width="900" Height="760"
        MinWidth="700" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>

    <!-- ── Dark ComboBox item ─────────────────────────────────────── -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background"   Value="#252535"/>
      <Setter Property="Foreground"   Value="#CDD6F4"/>
      <Setter Property="Padding"      Value="10,6"/>
      <Setter Property="FontSize"     Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="ItemBd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="ItemBd" Property="Background" Value="#313244"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBd" Property="Background" Value="#3c3f5c"/>
                <Setter Property="Foreground" Value="#89B4FA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Dark ComboBox (full template so popup is also dark) ───── -->
    <Style TargetType="ComboBox">
      <Setter Property="Background"      Value="#313244"/>
      <Setter Property="Foreground"      Value="#CDD6F4"/>
      <Setter Property="BorderBrush"     Value="#45475A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,5"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Height"          Value="30"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="ToggleBtn"
                            Focusable="False"
                            IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                        RelativeSource={RelativeSource TemplatedParent}}"
                            ClickMode="Press">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="TgBd"
                            Background="#313244"
                            BorderBrush="#45475A" BorderThickness="1"
                            CornerRadius="3">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                                          VerticalAlignment="Center"/>
                        <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="#8892A4" HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="TgBd" Property="BorderBrush" Value="#89B4FA"/>
                      </Trigger>
                      <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="TgBd" Property="BorderBrush" Value="#89B4FA"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>

              <ContentPresenter x:Name="ContentSite"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="10,0,28,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"/>

              <TextBox x:Name="PART_EditableTextBox"
                       Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                       Margin="3,3,23,3" Focusable="True"
                       Background="Transparent" Foreground="#CDD6F4"
                       BorderThickness="0"/>

              <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Grid x:Name="DropDown"
                      SnapsToDevicePixels="True"
                      MinWidth="{TemplateBinding ActualWidth}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <Border x:Name="DropDownBorder"
                          Background="#252535" BorderBrush="#45475A" BorderThickness="1"
                          CornerRadius="0,0,3,3">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <StackPanel IsItemsHost="True"
                                  KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#45475A"/>
                <Setter Property="Background" Value="#252535"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
      <Setter Property="Background"               Value="#313244"/>
      <Setter Property="Foreground"               Value="#CDD6F4"/>
      <Setter Property="BorderBrush"              Value="#45475A"/>
      <Setter Property="BorderThickness"          Value="1"/>
      <Setter Property="Padding"                  Value="8,5"/>
      <Setter Property="FontSize"                 Value="12"/>
      <Setter Property="Height"                   Value="30"/>
      <Setter Property="CaretBrush"               Value="#89B4FA"/>
      <Setter Property="SelectionBrush"           Value="#89B4FA"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="#89B4FA"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#6C7086"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ── Labels ─────────────────────────────────────────────────── -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#8892A4"/>
      <Setter Property="FontSize"   Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin"     Value="0,0,0,5"/>
    </Style>

    <!-- ── Base button ───────────────────────────────────────────── -->
    <Style x:Key="BtnBase" TargetType="Button">
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="22,9"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#89B4FA"/>
      <Setter Property="Foreground" Value="#1E1E2E"/>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
    </Style>

    <!-- ── Segment buttons (scope / mode toggles) ────────────────── -->
    <Style x:Key="SegBtnActive" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#89B4FA"/>
      <Setter Property="Foreground" Value="#1E1E2E"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Padding"    Value="20,7"/>
    </Style>

    <Style x:Key="SegBtnInactive" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#8892A4"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Padding"    Value="20,7"/>
    </Style>

    <!-- ── Section header (collapsible panels) ───────────────────── -->
    <Style x:Key="BtnSectionHeader" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background"                 Value="#252535"/>
      <Setter Property="Foreground"                 Value="#8892A4"/>
      <Setter Property="Padding"                    Value="24,10"/>
      <Setter Property="FontSize"                   Value="11"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- ── DataGrid ───────────────────────────────────────────────── -->
    <Style TargetType="DataGrid">
      <Setter Property="Background"               Value="#181825"/>
      <Setter Property="Foreground"               Value="#CDD6F4"/>
      <Setter Property="BorderThickness"          Value="0"/>
      <Setter Property="RowBackground"            Value="#181825"/>
      <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
      <Setter Property="VerticalGridLinesBrush"   Value="#313244"/>
      <Setter Property="FontSize"                 Value="12"/>
      <Setter Property="SelectionMode"            Value="Single"/>
      <Setter Property="CanUserAddRows"           Value="False"/>
      <Setter Property="CanUserDeleteRows"        Value="False"/>
      <Setter Property="IsReadOnly"               Value="True"/>
      <Setter Property="AutoGenerateColumns"      Value="False"/>
      <Setter Property="HeadersVisibility"        Value="Column"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background"      Value="#313244"/>
      <Setter Property="Foreground"      Value="#89B4FA"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="Padding"         Value="12,8"/>
      <Setter Property="BorderBrush"     Value="#45475A"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="BorderThickness"   Value="0"/>
      <Setter Property="Padding"           Value="12,6"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="{Binding RowBackground}"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#313244"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ── ListBox + CheckBox for family filter ───────────────────── -->
    <Style TargetType="ListBox">
      <Setter Property="Background"      Value="#181825"/>
      <Setter Property="BorderBrush"     Value="#45475A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="6"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Padding"    Value="4,2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FamilyCheckBox" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Margin"     Value="0,3"/>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- 0: Header -->
      <RowDefinition Height="1"/>      <!-- 1: Separator -->
      <RowDefinition Height="Auto"/>   <!-- 2: Settings (scrollable) -->
      <RowDefinition Height="1"/>      <!-- 3: Separator -->
      <RowDefinition Height="Auto"/>   <!-- 4: Preview label + badges -->
      <RowDefinition Height="*"/>      <!-- 5: DataGrid -->
      <RowDefinition Height="Auto"/>   <!-- 6: Conflict warning -->
      <RowDefinition Height="Auto"/>   <!-- 7: Bottom bar -->
    </Grid.RowDefinitions>

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="#181825" Padding="24,18,24,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="ELLAH-ColNum Pro"
                     FontSize="20" FontWeight="Bold" Foreground="#89B4FA"/>
          <TextBlock Text="Column Numbering — Settings &amp; Preview"
                     FontSize="12" Foreground="#6C7086" Margin="0,3,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="#252540" CornerRadius="12" Padding="12,5" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtPositionCount" FontSize="18" FontWeight="Bold" Foreground="#89B4FA"/>
              <TextBlock Text=" positions" FontSize="11" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,2"/>
            </StackPanel>
          </Border>
          <Border Background="#1e2e20" CornerRadius="12" Padding="12,5">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtElementCount" FontSize="18" FontWeight="Bold" Foreground="#A6E3A1"/>
              <TextBlock Text=" elements" FontSize="11" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,2"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Rectangle Grid.Row="1" Fill="#313244"/>

    <!-- ── Settings (all in one scrollable area) ──────────────────── -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="350"
                  Background="#1E1E2E">
      <StackPanel>

        <!-- ── SCOPE ─────────────────────────────────────────────── -->
        <Border Background="#181825" Padding="20,12">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="SCOPE" Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11"/>
            <Button x:Name="BtnFullProject"    Tag="FullProject"
                    Content="FULL PROJECT"     Click="BtnScope_Click"/>
            <Rectangle Width="1" Fill="#45475A" Margin="2,4,2,4"/>
            <Button x:Name="BtnSpecificFloor"  Tag="SpecificFloor"
                    Content="SPECIFIC FLOOR"   Click="BtnScope_Click"/>
            <ComboBox x:Name="CmbSpecificFloor" Width="190" Margin="14,0,0,0"
                      Visibility="Collapsed"
                      SelectionChanged="CmbSettings_SelectionChanged"
                      ToolTip="Number only the columns whose base level is this floor">
              <ComboBoxItem Tag="" Content="(select a floor)"/>
            </ComboBox>
          </StackPanel>
        </Border>

        <!-- ── METHOD ────────────────────────────────────────────── -->
        <Border Background="#252535" Padding="20,10"
                BorderBrush="#313244" BorderThickness="0,1,0,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="METHOD" Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11"/>
            <Button x:Name="BtnSmartNumbering" Tag="Smart"
                    Content="SMART NUMBERING"  Click="BtnMode_Click"/>
            <Rectangle Width="1" Fill="#45475A" Margin="2,4,2,4"/>
            <Button x:Name="BtnChooseYourWay"  Tag="ChooseYourWay"
                    Content="CHOOSE YOUR WAY"  Click="BtnMode_Click"/>
          </StackPanel>
        </Border>

        <!-- ── SMART NUMBERING panel ─────────────────────────────── -->
        <Border x:Name="PanelSmartNumbering" Background="#1E1E2E" Padding="24,16"
                BorderBrush="#313244" BorderThickness="0,1,0,0">
          <StackPanel>

            <!-- Mode / Prefix / Suffix / Start Number -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="MODE" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbMode" Width="150"
                          SelectionChanged="CmbSettings_SelectionChanged"
                          ToolTip="How to handle columns that already have a Mark value">
                  <ComboBoxItem Tag="SmartContinue" Content="Smart Continue"/>
                  <ComboBoxItem Tag="AddOnly"       Content="Add Only (Empty)"/>
                  <ComboBoxItem Tag="Override"      Content="Override All"/>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="PREFIX" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtPrefix" Width="80"
                         LostFocus="TxtSettings_LostFocus" KeyDown="TxtSettings_KeyDown"
                         ToolTip="Text prepended before the number (e.g. C- → C-1)"/>
              </StackPanel>

              <StackPanel Grid.Column="4">
                <TextBlock Text="SUFFIX" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtSuffix" Width="80"
                         LostFocus="TxtSettings_LostFocus" KeyDown="TxtSettings_KeyDown"
                         ToolTip="Text appended after the number"/>
              </StackPanel>

              <StackPanel Grid.Column="6">
                <TextBlock Text="START NUMBER" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtStartNumber" Width="90"
                         LostFocus="TxtSettings_LostFocus" KeyDown="TxtSettings_KeyDown"
                         ToolTip="First number assigned to the first column position"/>
              </StackPanel>
            </Grid>

            <!-- Sort Order (8 directions — screen-relative, not compass) -->
            <StackPanel Margin="0,14,0,0">
              <TextBlock Text="SORT ORDER" Style="{StaticResource LabelStyle}"/>
              <ComboBox x:Name="CmbSort" Width="440"
                        SelectionChanged="CmbSettings_SelectionChanged"
                        ToolTip="Numbering order based on visual position on screen — TOP/BOTTOM/LEFT/RIGHT are screen directions, independent of project north">
                <ComboBoxItem Tag="TopLeftToRight" Content="TOP-LEFT → Right ↓   (row by row, moving down)"/>
                <ComboBoxItem Tag="RightToLeft"    Content="TOP-RIGHT → Left ↓   (row by row, moving down)"/>
                <ComboBoxItem Tag="LeftToRight"    Content="BOTTOM-LEFT → Right ↑   (row by row, moving up)"/>
                <ComboBoxItem Tag="RightToLeftUp"  Content="BOTTOM-RIGHT → Left ↑   (row by row, moving up)"/>
                <ComboBoxItem Tag="TopToBottom"    Content="TOP-LEFT ↓ Column   (column by column, moving right)"/>
                <ComboBoxItem Tag="TopBottomLeft"  Content="TOP-RIGHT ↓ Column   (column by column, moving left)"/>
                <ComboBoxItem Tag="BottomToTop"    Content="BOTTOM-LEFT ↑ Column   (column by column, moving right)"/>
                <ComboBoxItem Tag="BottomTopLeft"  Content="BOTTOM-RIGHT ↑ Column   (column by column, moving left)"/>
              </ComboBox>
              <TextBlock Text="TOP / BOTTOM / LEFT / RIGHT = screen position, not compass north"
                         Foreground="#45475A" FontSize="10" Margin="0,5,0,0"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ── CHOOSE YOUR WAY panel ─────────────────────────────── -->
        <Border x:Name="PanelChooseYourWay" Background="#1E1E2E" Padding="24,16"
                BorderBrush="#313244" BorderThickness="0,1,0,0" Visibility="Collapsed">
          <StackPanel>

            <!-- Description -->
            <Border Background="#252535" CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
              <TextBlock Foreground="#89B4FA" FontSize="12" TextWrapping="Wrap"
                         Text="Choose the first column you want numbering to start from, then select the direction. Click CHOOSE COLUMN to pick directly in the plan."/>
            </Border>

            <!-- Sort direction + reference floor -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="SORT DIRECTION" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbChooseWaySort" Width="310"
                          SelectionChanged="CmbSettings_SelectionChanged"
                          ToolTip="Direction the numbering continues after the chosen starting column">
                  <ComboBoxItem Tag="TopLeftToRight" Content="TOP-LEFT → Right ↓   (row by row, down)"/>
                  <ComboBoxItem Tag="RightToLeft"    Content="TOP-RIGHT → Left ↓   (row by row, down)"/>
                  <ComboBoxItem Tag="LeftToRight"    Content="BOTTOM-LEFT → Right ↑   (row by row, up)"/>
                  <ComboBoxItem Tag="RightToLeftUp"  Content="BOTTOM-RIGHT → Left ↑   (row by row, up)"/>
                  <ComboBoxItem Tag="TopToBottom"    Content="TOP-LEFT ↓ Column   (column, right)"/>
                  <ComboBoxItem Tag="TopBottomLeft"  Content="TOP-RIGHT ↓ Column   (column, left)"/>
                  <ComboBoxItem Tag="BottomToTop"    Content="BOTTOM-LEFT ↑ Column   (column, right)"/>
                  <ComboBoxItem Tag="BottomTopLeft"  Content="BOTTOM-RIGHT ↑ Column   (column, left)"/>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="REFERENCE FLOOR (optional)" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbChooseWayFloor" Width="210"
                          SelectionChanged="CmbSettings_SelectionChanged"
                          ToolTip="Auto-filled when you pick a column. You can also set it manually.">
                  <ComboBoxItem Tag="" Content="(auto — from picked column)"/>
                </ComboBox>
                <TextBlock Text="Filled automatically when you choose a column"
                           Foreground="#45475A" FontSize="10" Margin="0,5,0,0"/>
              </StackPanel>
            </Grid>

            <!-- CHOOSE COLUMN button -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
              <Button x:Name="ChooseColumnBtn"
                      Content="⊕  CHOOSE COLUMN"
                      Style="{StaticResource BtnPrimary}"
                      Padding="22,10" FontSize="13"
                      Click="ChooseColumnBtn_Click"
                      ToolTip="Click to pick a starting column directly in the Revit plan view"/>
              <TextBlock Text="  ← Click a column in the plan. The dialog will reopen with that column as #1."
                         Foreground="#45475A" FontSize="11" VerticalAlignment="Center"
                         TextWrapping="Wrap" MaxWidth="300"/>
            </StackPanel>

            <!-- Anchor info (shown after pick) -->
            <Border x:Name="AnchorInfoBorder" Visibility="Collapsed"
                    Background="#1b3a2a" CornerRadius="6" Padding="14,10" Margin="0,12,0,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="▶  Starting column: " Foreground="#A6E3A1"
                           FontSize="12" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtAnchorInfo" Foreground="#CDD6F4"
                           FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- ── ADVANCED SETTINGS (collapsible) ───────────────────── -->
        <Border BorderBrush="#313244" BorderThickness="0,1,0,0">
          <StackPanel>
            <Button x:Name="BtnExpandAdvanced" Style="{StaticResource BtnSectionHeader}"
                    Click="BtnExpandAdvanced_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ADVANCED SETTINGS" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold" Foreground="#8892A4"/>
                <TextBlock x:Name="TxtAdvancedArrow" Text="▸" Grid.Column="1"
                           Foreground="#8892A4" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
              </Grid>
            </Button>

            <Grid x:Name="PanelAdvancedContent" Visibility="Collapsed"
                  Margin="24,8,24,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Floor Discipline + Reference Floor -->
              <StackPanel Grid.Column="0">
                <TextBlock Text="FLOOR DISCIPLINE" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbFloorDiscipline" Width="220"
                          SelectionChanged="CmbFloorDiscipline_SelectionChanged"
                          ToolTip="Filter the floor list to levels in views of this discipline">
                  <ComboBoxItem Tag="All" Content="All disciplines"/>
                </ComboBox>
                <TextBlock Text="REFERENCE FLOOR" Style="{StaticResource LabelStyle}"
                           Margin="0,12,0,5"/>
                <ComboBox x:Name="CmbReferenceFloor" Width="220"
                          SelectionChanged="CmbSettings_SelectionChanged"
                          ToolTip="Columns on this floor are always numbered first — consecutively — before all other floors.">
                  <ComboBoxItem Tag="" Content="(all floors — default)"/>
                </ComboBox>
                <TextBlock Text="Reference floor columns always get consecutive numbers first"
                           Foreground="#45475A" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
              </StackPanel>

              <!-- Tolerances -->
              <StackPanel Grid.Column="2">
                <TextBlock Text="POSITION TOLERANCE" Style="{StaticResource LabelStyle}"
                           ToolTip="Center-to-center XY distance: two columns on different floors share the same number only if their centers are closer than this value."/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="106"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="TxtTolerance" Grid.Column="0" Text="5"
                           LostFocus="TxtSettings_LostFocus" KeyDown="TxtSettings_KeyDown"
                           ToolTip="Measured center-to-center between columns on different floors. 15 cm handles minor modelling offsets."/>
                  <ComboBox x:Name="CmbToleranceUnit" Grid.Column="2"
                            SelectionChanged="CmbSettings_SelectionChanged">
                    <ComboBoxItem Tag="cm" Content="cm"/>
                    <ComboBoxItem Tag="mm" Content="mm"/>
                    <ComboBoxItem Tag="m"  Content="m"/>
                    <ComboBoxItem Tag="ft" Content="ft"/>
                  </ComboBox>
                </Grid>
                <TextBlock x:Name="TxtToleranceHint" Text=""
                           Foreground="#45475A" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="ROW GROUPING TOLERANCE" Style="{StaticResource LabelStyle}"
                           Margin="0,14,0,5"
                           ToolTip="Center-to-center perpendicular distance: two columns are placed in the same row only if their centers are closer than this in the perpendicular direction (Y for horizontal sorts, X for vertical sorts)."/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="106"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="TxtRowTolerance" Grid.Column="0" Text="50"
                           LostFocus="TxtSettings_LostFocus" KeyDown="TxtSettings_KeyDown"
                           ToolTip="Measured center-to-center in the perpendicular direction. 50 cm suits most structural grids."/>
                  <ComboBox x:Name="CmbRowToleranceUnit" Grid.Column="2"
                            SelectionChanged="CmbSettings_SelectionChanged">
                    <ComboBoxItem Tag="cm" Content="cm"/>
                    <ComboBoxItem Tag="mm" Content="mm"/>
                    <ComboBoxItem Tag="m"  Content="m"/>
                    <ComboBoxItem Tag="ft" Content="ft"/>
                  </ComboBox>
                </Grid>
                <TextBlock Text="Center-to-center, perpendicular direction"
                           Foreground="#45475A" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtRowToleranceAutoHint" Text=""
                           Foreground="#7E22CE" FontSize="10" FontStyle="Italic"
                           Margin="0,3,0,0" TextWrapping="Wrap"/>
              </StackPanel>

              <!-- Target Parameter -->
              <StackPanel Grid.Column="4">
                <TextBlock Text="WRITE NUMBER TO PARAMETER" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbTargetParam" Width="220"
                          SelectionChanged="CmbSettings_SelectionChanged"
                          ToolTip="The Revit parameter that receives the assigned number. Default: Mark.">
                  <ComboBoxItem Tag="" Content="Mark (default)"/>
                </ComboBox>
                <TextBlock Text="Parameter where the number is written"
                           Foreground="#45475A" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ── FAMILY FILTER (collapsible) ───────────────────────── -->
        <Border BorderBrush="#313244" BorderThickness="0,1,0,0">
          <StackPanel>
            <Button x:Name="BtnExpandFamilyFilter" Style="{StaticResource BtnSectionHeader}"
                    Click="BtnExpandFamilyFilter_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FAMILY FILTER" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold" Foreground="#8892A4"/>
                <TextBlock x:Name="TxtFamilyFilterArrow" Text="▸" Grid.Column="1"
                           Foreground="#8892A4" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
              </Grid>
            </Button>

            <StackPanel x:Name="PanelFamilyFilterContent" Visibility="Collapsed"
                        Margin="24,4,24,14">
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CATEGORY"
                           Style="{StaticResource LabelStyle}"
                           VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbFamilyCategory" Grid.Column="2"
                          SelectionChanged="CmbFamilyCategory_SelectionChanged"
                          ToolTip="Select which Revit category to work with.">
                  <ComboBoxItem Tag="Structural Columns" Content="Structural Columns"/>
                </ComboBox>
              </Grid>

              <TextBlock Text="Check families to include. Leave all unchecked to include every family in this category (default)."
                         Foreground="#8892A4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

              <ListBox x:Name="FamilyListBox" Height="110" SelectionMode="Multiple"/>

              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Select All" Style="{StaticResource BtnSecondary}"
                        Padding="14,5" FontSize="11"
                        Click="SelectAllFamilies_Click" Margin="0,0,8,0"/>
                <Button Content="Clear All" Style="{StaticResource BtnSecondary}"
                        Padding="14,5" FontSize="11"
                        Click="ClearAllFamilies_Click"/>
                <TextBlock x:Name="TxtFamilyCount" Foreground="#585B70" FontSize="10"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Rectangle Grid.Row="3" Fill="#313244"/>

    <!-- ── Preview label + badges ─────────────────────────────────── -->
    <Border Grid.Row="4" Background="#181825" Padding="24,10">
      <Grid>
        <TextBlock Text="LIVE PREVIEW" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Border x:Name="BadgeNew" CornerRadius="10" Padding="10,3"
                  Background="#1e2f4a" Margin="0,0,6,0">
            <TextBlock x:Name="TxtBadgeNew" Text="0 new"
                       Foreground="#89B4FA" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border x:Name="BadgeKeep" CornerRadius="10" Padding="10,3"
                  Background="#1b3a2a" Margin="0,0,6,0">
            <TextBlock x:Name="TxtBadgeKeep" Text="0 kept"
                       Foreground="#A6E3A1" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border x:Name="BadgeComplete" CornerRadius="10" Padding="10,3"
                  Background="#2a1e3a" Margin="0,0,6,0" Visibility="Collapsed">
            <TextBlock x:Name="TxtBadgeComplete" Text="0 completed"
                       Foreground="#CBA6F7" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border x:Name="BadgeConflict" CornerRadius="10" Padding="10,3"
                  Background="#3a2a1b" Visibility="Collapsed">
            <TextBlock x:Name="TxtBadgeConflict" Text="0 conflicts"
                       Foreground="#F9E2AF" FontSize="10" FontWeight="SemiBold"/>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── DataGrid ───────────────────────────────────────────────── -->
    <DataGrid x:Name="PreviewGrid" Grid.Row="5"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              EnableRowVirtualization="True"
              SelectionChanged="PreviewGrid_SelectionChanged">
      <DataGrid.Columns>
        <DataGridTextColumn Header="#" Width="46" Binding="{Binding Sequence}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="Foreground" Value="#6C7086"/>
              <Setter Property="Padding"    Value="12,6"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <DataGridTextColumn Header="Grid / Position" Width="120" Binding="{Binding GridRef}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="Padding"    Value="12,6"/>
              <Setter Property="Foreground" Value="#CDD6F4"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <DataGridTextColumn Header="Family" Width="180" Binding="{Binding FamilyName}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="Padding"    Value="12,6"/>
              <Setter Property="Foreground" Value="#585B70"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <DataGridTextColumn Header="Floors" Width="58" Binding="{Binding FloorCount}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="Padding"             Value="12,6"/>
              <Setter Property="Foreground"          Value="#6C7086"/>
              <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <DataGridTextColumn Header="Current Mark" Width="110" Binding="{Binding CurrentMark}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="Padding"    Value="12,6"/>
              <Setter Property="Foreground" Value="#585b70"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <DataGridTemplateColumn Header="New Mark" Width="110">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding NewMark}" Padding="12,6"
                         Foreground="{Binding NewMarkForeground}" FontWeight="SemiBold"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <DataGridTemplateColumn Header="Status" Width="100">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Border Background="{Binding StatusBackground}" CornerRadius="4" Padding="8,3"
                      HorizontalAlignment="Left" Margin="8,4">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusForeground}"
                           FontSize="10" FontWeight="SemiBold"/>
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>

    <!-- ── Conflict warning ───────────────────────────────────────── -->
    <Border x:Name="ConflictWarning" Grid.Row="6" Background="#2a2010"
            Padding="24,10" Visibility="Collapsed">
      <TextBlock x:Name="TxtConflictWarning"
                 Foreground="#F9E2AF" FontSize="12" TextWrapping="Wrap"/>
    </Border>

    <!-- ── Bottom bar ─────────────────────────────────────────────── -->
    <Border Grid.Row="7" Background="#181825" Padding="24,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TxtSummary" Foreground="#6C7086"
                   FontSize="12" VerticalAlignment="Center"/>
        <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel"
                Style="{StaticResource BtnSecondary}" Click="CancelBtn_Click"/>
        <Button x:Name="EditMarksBtn" Grid.Column="3"
                Content="✎  Edit Column Marks"
                Style="{StaticResource BtnSecondary}"
                Click="EditMarksBtn_Click"
                ToolTip="Close this dialog and pick columns one-by-one to manually correct their marks."/>
        <Button x:Name="ApplyBtn"  Grid.Column="5"
                Content="▶  Apply Numbering  (Enter)"
                Style="{StaticResource BtnPrimary}"
                Click="ApplyBtn_Click" IsDefault="True"/>
      </Grid>
    </Border>

  </Grid>
</Window>
