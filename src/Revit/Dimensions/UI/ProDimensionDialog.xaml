<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EllahColNum.Revit.Dimensions.UI.ProDimensionDialog"
        Title="ELLAH-ColNum Pro — Pro Dimensions"
        Width="780" Height="720"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>

    <!-- ── Dark ComboBoxItem ───────────────────────────────────────── -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background"   Value="#252535"/>
      <Setter Property="Foreground"   Value="#CDD6F4"/>
      <Setter Property="Padding"      Value="10,6"/>
      <Setter Property="FontSize"     Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="ItemBd" Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="ItemBd" Property="Background" Value="#313244"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBd" Property="Background" Value="#3c3f5c"/>
                <Setter Property="Foreground" Value="#89B4FA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Dark ComboBox ──────────────────────────────────────────── -->
    <Style TargetType="ComboBox">
      <Setter Property="Background"      Value="#313244"/>
      <Setter Property="Foreground"      Value="#CDD6F4"/>
      <Setter Property="BorderBrush"     Value="#45475A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,5"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Height"          Value="30"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="ToggleBtn" Focusable="False"
                            IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                        RelativeSource={RelativeSource TemplatedParent}}"
                            ClickMode="Press">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="TgBd" Background="#313244"
                            BorderBrush="#45475A" BorderThickness="1" CornerRadius="3">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="#8892A4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="TgBd" Property="BorderBrush" Value="#89B4FA"/>
                      </Trigger>
                      <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="TgBd" Property="BorderBrush" Value="#89B4FA"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
              <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="10,0,28,0" VerticalAlignment="Center"/>
              <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Grid SnapsToDevicePixels="True"
                      MinWidth="{TemplateBinding ActualWidth}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <Border Background="#252535" BorderBrush="#45475A" BorderThickness="1"
                          CornerRadius="0,0,3,3">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <StackPanel IsItemsHost="True"
                                  KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
      <Setter Property="Background"               Value="#313244"/>
      <Setter Property="Foreground"               Value="#CDD6F4"/>
      <Setter Property="BorderBrush"              Value="#45475A"/>
      <Setter Property="BorderThickness"          Value="1"/>
      <Setter Property="Padding"                  Value="8,5"/>
      <Setter Property="FontSize"                 Value="12"/>
      <Setter Property="Height"                   Value="30"/>
      <Setter Property="CaretBrush"               Value="#89B4FA"/>
      <Setter Property="SelectionBrush"           Value="#89B4FA"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Style.Triggers>
        <Trigger Property="IsFocused"   Value="True">
          <Setter Property="BorderBrush" Value="#89B4FA"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#6C7086"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ── Labels ─────────────────────────────────────────────────── -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#8892A4"/>
      <Setter Property="FontSize"   Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin"     Value="0,0,0,5"/>
    </Style>

    <!-- ── Layer row background ──────────────────────────────────── -->
    <Style x:Key="LayerRow" TargetType="Border">
      <Setter Property="Background"    Value="#252535"/>
      <Setter Property="CornerRadius"  Value="5"/>
      <Setter Property="Padding"       Value="12,10"/>
      <Setter Property="Margin"        Value="0,0,0,6"/>
    </Style>

    <!-- ── Layer label ───────────────────────────────────────────── -->
    <Style x:Key="LayerLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Width"      Value="110"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Count badge ───────────────────────────────────────────── -->
    <Style x:Key="CountBadge" TargetType="Border">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding"      Value="8,3"/>
      <Setter Property="Margin"       Value="6,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Layer CheckBox ────────────────────────────────────────── -->
    <Style x:Key="LayerCheck" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin"     Value="0,0,12,0"/>
    </Style>

    <!-- ── View CheckBox ─────────────────────────────────────────── -->
    <Style x:Key="ViewCheckBox" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Margin"     Value="0,3"/>
    </Style>

    <!-- ── Buttons ────────────────────────────────────────────────── -->
    <Style x:Key="BtnBase" TargetType="Button">
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="22,9"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#89B4FA"/>
      <Setter Property="Foreground" Value="#1E1E2E"/>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
    </Style>

    <!-- ── ListBox ────────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
      <Setter Property="Background"      Value="#181825"/>
      <Setter Property="BorderBrush"     Value="#45475A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="6"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Padding"    Value="4,2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- Header -->
      <RowDefinition Height="1"/>      <!-- Divider -->
      <RowDefinition Height="Auto"/>   <!-- Layer settings -->
      <RowDefinition Height="1"/>      <!-- Divider -->
      <RowDefinition Height="Auto"/>   <!-- Discipline filter + view bar -->
      <RowDefinition Height="*"/>      <!-- View ListBox -->
      <RowDefinition Height="Auto"/>   <!-- Bottom bar -->
    </Grid.RowDefinitions>

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="#181825" Padding="24,18,24,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="ELLAH-ColNum Pro"
                     FontSize="20" FontWeight="Bold" Foreground="#89B4FA"/>
          <TextBlock Text="Pro Dimensions — columns · walls · openings · grids"
                     FontSize="12" Foreground="#6C7086" Margin="0,3,0,0"/>
        </StackPanel>
        <!-- Element count badges -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Style="{StaticResource CountBadge}" Background="#1e2e20"
                  ToolTip="Structural columns found">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtColCount" FontSize="16" FontWeight="Bold" Foreground="#A6E3A1"/>
              <TextBlock Text=" col" FontSize="10" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CountBadge}" Background="#2e2020"
                  ToolTip="Walls found">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtWallCount" FontSize="16" FontWeight="Bold" Foreground="#F38BA8"/>
              <TextBlock Text=" wall" FontSize="10" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CountBadge}" Background="#2e2a1a"
                  ToolTip="Doors and windows found">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtOpeningCount" FontSize="16" FontWeight="Bold" Foreground="#FAB387"/>
              <TextBlock Text=" open" FontSize="10" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CountBadge}" Background="#252540"
                  ToolTip="Grid lines found">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtGridCount" FontSize="16" FontWeight="Bold" Foreground="#89B4FA"/>
              <TextBlock Text=" grid" FontSize="10" Foreground="#6C7086"
                         VerticalAlignment="Bottom" Margin="0,0,0,1"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Rectangle Grid.Row="1" Fill="#313244"/>

    <!-- ── Layer settings ─────────────────────────────────────────── -->
    <Border Grid.Row="2" Background="#1E1E2E" Padding="24,16,24,12">
      <StackPanel>

        <TextBlock Text="DIMENSION LAYERS" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>

        <!-- Column headers -->
        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="24"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="LAYER"        Style="{StaticResource LabelStyle}" Grid.Column="0"/>
          <TextBlock Text="DIMENSION TYPE" Style="{StaticResource LabelStyle}" Grid.Column="3"/>
          <TextBlock Text="OFFSET" Style="{StaticResource LabelStyle}" Grid.Column="5"/>
        </Grid>

        <!-- Grid layer (green) -->
        <Border Style="{StaticResource LayerRow}" BorderBrush="#1e4a30" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <CheckBox x:Name="ChkLayerGrid" IsChecked="True" Style="{StaticResource LayerCheck}"
                        Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
              <Border Width="10" Height="10" Background="#A6E3A1" CornerRadius="2"
                      VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Grids" Style="{StaticResource LayerLabel}"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Grid lines only" Foreground="#45475A"
                       FontSize="11" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbTypeGrid" Grid.Column="3"
                      ToolTip="DimensionType for grid dimension strings"/>
            <TextBox  x:Name="TxtOffsetGrid" Grid.Column="5" Text="3.0"
                      ToolTip="Offset from building edge in metres"/>
            <TextBlock Grid.Column="6" Text="m" Foreground="#8892A4" FontSize="12"
                       VerticalAlignment="Center" Margin="4,0,0,0"/>
          </Grid>
        </Border>

        <!-- Column layer (blue) -->
        <Border Style="{StaticResource LayerRow}" BorderBrush="#1a2e4a" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <CheckBox x:Name="ChkLayerColumns" IsChecked="True" Style="{StaticResource LayerCheck}"
                        Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
              <Border Width="10" Height="10" Background="#89B4FA" CornerRadius="2"
                      VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Columns" Style="{StaticResource LayerLabel}"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Structural column centres" Foreground="#45475A"
                       FontSize="11" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbTypeColumns" Grid.Column="3"
                      ToolTip="DimensionType for column dimension strings"/>
            <TextBox  x:Name="TxtOffsetColumns" Grid.Column="5" Text="2.0"
                      ToolTip="Offset from building edge in metres"/>
            <TextBlock Grid.Column="6" Text="m" Foreground="#8892A4" FontSize="12"
                       VerticalAlignment="Center" Margin="4,0,0,0"/>
          </Grid>
        </Border>

        <!-- Wall layer (red) -->
        <Border Style="{StaticResource LayerRow}" BorderBrush="#4a1a1a" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <CheckBox x:Name="ChkLayerWalls" IsChecked="True" Style="{StaticResource LayerCheck}"
                        Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
              <Border Width="10" Height="10" Background="#F38BA8" CornerRadius="2"
                      VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Walls" Style="{StaticResource LayerLabel}"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Wall finish faces" Foreground="#45475A"
                       FontSize="11" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbTypeWalls" Grid.Column="3"
                      ToolTip="DimensionType for wall dimension strings"/>
            <TextBox  x:Name="TxtOffsetWalls" Grid.Column="5" Text="1.0"
                      ToolTip="Offset from building edge in metres"/>
            <TextBlock Grid.Column="6" Text="m" Foreground="#8892A4" FontSize="12"
                       VerticalAlignment="Center" Margin="4,0,0,0"/>
          </Grid>
        </Border>

        <!-- Opening layer (orange) -->
        <Border Style="{StaticResource LayerRow}" BorderBrush="#4a3210" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
              <CheckBox x:Name="ChkLayerOpenings" IsChecked="True" Style="{StaticResource LayerCheck}"
                        Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
              <Border Width="10" Height="10" Background="#FAB387" CornerRadius="2"
                      VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Openings" Style="{StaticResource LayerLabel}"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Doors and windows" Foreground="#45475A"
                       FontSize="11" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbTypeOpenings" Grid.Column="3"
                      ToolTip="DimensionType for opening dimension strings"/>
            <TextBox  x:Name="TxtOffsetOpenings" Grid.Column="5" Text="0.5"
                      ToolTip="Offset from building edge in metres"/>
            <TextBlock Grid.Column="6" Text="m" Foreground="#8892A4" FontSize="12"
                       VerticalAlignment="Center" Margin="4,0,0,0"/>
          </Grid>
        </Border>

      </StackPanel>
    </Border>

    <Rectangle Grid.Row="3" Fill="#313244"/>

    <!-- ── Discipline filter + views bar ─────────────────────────── -->
    <Border Grid.Row="4" Background="#181825" Padding="24,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200"/>
          <ColumnDefinition Width="20"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="VIEW DISCIPLINE FILTER" Foreground="#8892A4"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox x:Name="CmbDiscipline" SelectionChanged="CmbDiscipline_SelectionChanged"/>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="SELECT VIEWS TO DIMENSION"
                   Foreground="#8892A4" FontSize="10" FontWeight="SemiBold"
                   VerticalAlignment="Bottom" Margin="0,0,0,6"/>
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
          <Button Content="Select All" Style="{StaticResource BtnSecondary}"
                  Padding="14,5" FontSize="11" Click="SelectAllViews_Click" Margin="0,0,8,0"/>
          <Button Content="Clear All"  Style="{StaticResource BtnSecondary}"
                  Padding="14,5" FontSize="11" Click="ClearAllViews_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── View ListBox ───────────────────────────────────────────── -->
    <ListBox x:Name="ViewListBox" Grid.Row="5" Margin="24,0,24,0"
             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

    <!-- ── Bottom bar ─────────────────────────────────────────────── -->
    <Border Grid.Row="6" Background="#181825" Padding="24,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TxtSummary" Foreground="#6C7086" FontSize="12" VerticalAlignment="Center"/>
        <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel"
                Style="{StaticResource BtnSecondary}" Click="CancelBtn_Click"/>
        <Button x:Name="ApplyBtn" Grid.Column="3" Content="▶  Apply Pro Dimensions  (Enter)"
                Style="{StaticResource BtnPrimary}" Click="ApplyBtn_Click" IsDefault="True"/>
      </Grid>
    </Border>

  </Grid>
</Window>
